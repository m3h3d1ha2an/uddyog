{
  "name": "uddyog",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint --write",
    "fmt": "biome format --write",
    "fix": "biome check --write",
    "tsc": "tsc --noEmit",
    "check": "bun run fix && bun run tsc",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:sync": "bun x auth@latest generate --config ./src/lib/better-auth/index.ts --output ./src/database/schema/auth.ts --yes",
    "auth:gen": "bun x auth@latest secret"
  },
  "dependencies": {
    "@fontsource-variable/public-sans": "^5.2.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/router-plugin": "^1.168.18",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.3",
    "drizzle-seed": "^0.3.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@netlify/vite-plugin-tanstack-start": "^1.3.15",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^1.0.0-rc.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}
